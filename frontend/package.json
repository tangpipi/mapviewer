    "esno": "^4.8.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.5"
